.hero-pills {
  margin-top: 18rpx;
}

.metric-value {
  font-size: 36rpx;
}

.metric-mini {
  font-size: 28rpx;
}

.helper-copy {
  margin-bottom: 18rpx;
}

.map-panel {
  overflow: hidden;
}

.run-map {
  width: 100%;
  height: calc(46vh + 20rpx);
  min-height: 420rpx;
  max-height: 620rpx;
  border-radius: 24rpx;
}

.map-placeholder {
  height: 320rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(212, 75, 43, 0.08), rgba(212, 75, 43, 0.02));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  margin-bottom: 20rpx;
}

.bullet-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.bullet-item {
  color: #75665b;
  font-size: 24rpx;
}

.bullet-warning {
  color: #a63a24;
}

.recovery-card {
  border: 2rpx solid rgba(212, 75, 43, 0.18);
  background: rgba(255, 248, 242, 0.96);
}

.run-metrics {
  margin-bottom: 20rpx;
}
