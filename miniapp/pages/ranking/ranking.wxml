<view class="page-wrap">
  <view class="hero-card">
    <view class="eyebrow">Ranking</view>
    <view class="hero-title">校园里程排行榜</view>
    <view class="hero-subtitle">本榜单按累计跑步距离排序，看看谁正在领跑本周校园节奏。</view>
  </view>

  <view wx:if="{{loading}}" class="panel-card">
    <view class="section-title">加载中</view>
    <view class="muted">正在获取最新排行榜数据。</view>
  </view>

  <view wx:if="{{!loading && errorMessage}}" class="panel-card">
    <view class="section-title">加载失败</view>
    <view class="muted">{{errorMessage}}</view>
    <button class="ghost-button" style="margin-top: 18rpx;" bindtap="loadData">重新加载</button>
  </view>

  <view wx:if="{{!loading && !errorMessage && ranking.length}}" class="panel-card">
    <block wx:for="{{ranking}}" wx:key="userId">
      <view class="rank-row">
        <view class="rank-left">
          <view class="rank-index">{{index + 1}}</view>
          <view>
            <view class="rank-name">{{item.displayName || '匿名同学'}}</view>
            <view class="muted">累计打卡持续发力中</view>
          </view>
        </view>
        <view class="pill">{{item.distanceKm || 0}} km</view>
      </view>
    </block>
  </view>

  <view wx:if="{{!loading && !errorMessage && !ranking.length}}" class="panel-card">
    <view class="section-title">暂无榜单数据</view>
    <view class="muted">当大家开始留下有效跑步记录后，这里会自动展示排名。</view>
  </view>
</view>
