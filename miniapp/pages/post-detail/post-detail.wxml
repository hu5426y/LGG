<view class="page-wrap">
  <view wx:if="{{loading}}" class="panel-card">
    <view class="section-title">加载中</view>
    <view class="muted">正在获取动态详情。</view>
  </view>

  <view wx:if="{{!loading && errorMessage}}" class="panel-card">
    <view class="section-title">加载失败</view>
    <view class="muted">{{errorMessage}}</view>
    <button class="ghost-button" style="margin-top: 18rpx;" bindtap="loadData">重新加载</button>
  </view>

  <block wx:if="{{!loading && !errorMessage && post}}">
    <view class="post-card detail-post">
      <view class="post-header">
        <view>
          <view class="post-author">{{post.user.displayName || '校园跑友'}}</view>
          <view class="muted">{{post.createdAt || '刚刚更新'}}</view>
        </view>
        <view class="pill">{{post.featured ? '推荐' : (post.reviewStatus || '已发布')}}</view>
      </view>
      <view class="divider"></view>
      <view class="content-block">{{post.content || '这条动态暂时没有内容。'}}</view>
      <view class="pill-row action-row">
        <view class="pill">点赞 {{post.likeCount || 0}}</view>
        <view class="pill">评论 {{post.commentCount || 0}}</view>
      </view>
      <view class="pill-row action-row">
        <button size="mini" class="ghost-button" bindtap="likePost">点赞</button>
        <button size="mini" class="ghost-button" bindtap="commentPost">评论</button>
        <button size="mini" class="ghost-button" bindtap="reportPost">举报</button>
      </view>
    </view>

    <view class="panel-card">
      <view class="section-title">评论区</view>
      <block wx:if="{{comments.length}}">
        <block wx:for="{{comments}}" wx:key="id">
          <view class="comment-row">
            <text class="comment-author">{{item.user.displayName || '同学'}}：</text>
            <text>{{item.content || '暂无评论内容'}}</text>
          </view>
        </block>
      </block>
      <view wx:else class="empty-state">还没有评论，来留下第一条互动吧。</view>
    </view>
  </block>
</view>
