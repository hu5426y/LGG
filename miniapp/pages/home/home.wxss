.home-shell {
  min-height: 100vh;
  padding-bottom: 16rpx;
}

.home-hero {
  margin-bottom: 20rpx;
  background: linear-gradient(145deg, rgba(255, 250, 244, 0.98), rgba(255, 239, 229, 0.96));
}

.home-map-panel {
  overflow: hidden;
}

.home-map {
  width: 100%;
  height: 46vh;
  min-height: 420rpx;
  max-height: 620rpx;
  border-radius: 24rpx;
}

.placeholder-map {
  background: linear-gradient(180deg, rgba(246, 226, 210, 0.95), rgba(247, 239, 229, 0.90));
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 420rpx;
  padding: 36rpx;
  box-sizing: border-box;
}

.map-placeholder-title {
  margin-bottom: 12rpx;
}

.home-map-meta {
  margin-top: 18rpx;
}

.hero-pills {
  margin-top: 18rpx;
}

.hero-action {
  margin-top: 22rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.floating-panel {
  margin-top: 0;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.shortcut-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 248, 241, 0.88);
}

.shortcut-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.banner-swiper {
  height: 280rpx;
}

.banner-slide {
  height: 100%;
  border-radius: 26rpx;
  padding: 28rpx;
  background-size: cover;
  background-position: center;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  color: #fffaf4;
}

.banner-chip {
  align-self: flex-start;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.18);
  font-size: 22rpx;
  margin-bottom: 18rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.banner-subtitle {
  font-size: 25rpx;
  color: rgba(255, 250, 244, 0.92);
}

.section-header {
  margin-bottom: 12rpx;
}

.section-tip,
.section-link {
  font-size: 24rpx;
  color: #b95c34;
}

.clickable-card {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 20rpx 48rpx rgba(133, 77, 36, 0.16);
}

.metric-highlight {
  position: relative;
  overflow: hidden;
}

.metric-foot {
  margin-top: 12rpx;
  color: #b95c34;
  font-size: 22rpx;
}

.mini-eyebrow {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(212, 75, 43, 0.10);
  color: #d44b2b;
  font-size: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  margin: 12rpx 0 10rpx;
}

.card-pills {
  margin-top: 18rpx;
}

.rank-row {
  padding: 10rpx 0;
}

.rank-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rank-badge {
  color: #d44b2b;
  font-weight: 700;
}
