<view class="page-wrap home-shell">
  <view class="hero-card home-hero">
    <view class="eyebrow">Campus Run</view>
    <view class="hero-title">欢迎回来，{{profile.displayName || '同学'}}</view>
    <view class="hero-subtitle">地图就是今天的主场。直接开始跑步，或者先看下打卡和计划推进。</view>
    <view class="pill-row hero-pills">
      <view class="pill">累计 {{profile.totalDistanceKm}} km</view>
      <view class="pill">积分 {{profile.points}}</view>
      <view class="pill">Lv.{{profile.levelValue}}</view>
    </view>
    <button class="accent-button hero-action" bindtap="goRun">立即开始跑步</button>
  </view>

  <view class="panel-card home-map-panel">
    <view class="row-between section-header">
      <view class="section-title">校园地图</view>
      <view class="section-link">{{latestRun ? '最近轨迹预览' : (mapReady ? '当前位置' : '等待定位')}}</view>
    </view>
    <map
      wx:if="{{showMap && mapReady}}"
      class="home-map"
      subkey="{{mapSubKey}}"
      latitude="{{mapLatitude}}"
      longitude="{{mapLongitude}}"
      scale="{{mapScale}}"
      markers="{{mapMarkers}}"
      polyline="{{mapPolyline}}"
      include-points="{{mapIncludePoints}}"
      show-location
    />
    <view wx:else class="home-map placeholder-map">
      <view class="section-title map-placeholder-title">等待地图数据</view>
      <view class="muted">拿到定位或最近一次跑步轨迹后，这里会显示路线预览。</view>
    </view>
    <view class="pill-row home-map-meta">
      <view class="pill">{{latestRun ? '已载入最近一次跑步轨迹' : (mapReady ? '已定位当前位置' : '暂未获取定位')}}</view>
      <view wx:if="{{currentPlan.template}}" class="pill">计划 Day {{currentPlan.currentDayIndex}}</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="panel-card">
    <view class="section-title">加载中</view>
    <view class="muted">正在同步首页地图与业务数据，请稍候。</view>
  </view>

  <view wx:if="{{!loading && errorMessage}}" class="panel-card">
    <view class="section-title">加载失败</view>
    <view class="muted">{{errorMessage}}</view>
    <button class="ghost-button" style="margin-top: 18rpx;" bindtap="loadData">重新加载</button>
  </view>

  <block wx:if="{{!loading && !errorMessage}}">
    <view class="summary-grid">
      <view class="metric-card metric-highlight">
        <view class="metric-label">今日打卡</view>
        <view class="metric-value">{{todayCheckin.checkedIn ? '已完成' : '未完成'}}</view>
        <view class="metric-foot">连续 {{todayCheckin.streakDays}} 天</view>
      </view>
      <view class="metric-card metric-highlight" bindtap="goGrowthCenter" hover-class="card-hover">
        <view class="metric-label">当前计划</view>
        <view class="metric-value">{{currentPlan.template ? currentPlan.template.title : '未选择'}}</view>
        <view class="metric-foot">{{currentPlan.template ? ('Day ' + currentPlan.currentDayIndex) : '进入成长中心选择'}}</view>
      </view>
    </view>

    <view class="panel-card floating-panel">
      <view class="row-between section-header">
        <view class="section-title">快捷入口</view>
        <view class="section-link">{{latestRun ? '已载入最近轨迹' : '已载入当前定位'}}</view>
      </view>
      <view class="shortcut-grid">
        <view class="shortcut-card" bindtap="goGrowthCenter">
          <view class="shortcut-title">计划与打卡</view>
          <view class="muted">任务 {{overview.tasks.length}} · 勋章 {{overview.badges.length}}</view>
        </view>
        <view class="shortcut-card" bindtap="goSocial">
          <view class="shortcut-title">跑友圈</view>
          <view class="muted">热门动态 {{homeData.hotPosts.length}}</view>
        </view>
        <view class="shortcut-card" bindtap="goActivities">
          <view class="shortcut-title">活动与训练</view>
          <view class="muted">推荐 {{homeData.recommendedActivities.length}}</view>
        </view>
        <view class="shortcut-card" bindtap="goRanking">
          <view class="shortcut-title">排行榜</view>
          <view class="muted">查看 Top 10</view>
        </view>
      </view>
    </view>

    <view class="panel-card">
      <view class="row-between section-header">
        <view class="section-title">排行榜 Top 3</view>
        <view class="section-link" bindtap="goRanking">查看完整榜单 →</view>
      </view>
      <block wx:if="{{homeData.leaderboard.length}}">
        <block wx:for="{{homeData.leaderboard}}" wx:key="userId">
          <view class="row-between list-row rank-row">
            <view class="rank-name">
              <text class="rank-badge">#{{index + 1}}</text>
              <text>{{item.displayName || '匿名同学'}}</text>
            </view>
            <view class="pill">{{item.distanceKm || 0}} km</view>
          </view>
        </block>
      </block>
      <view wx:else class="empty-state">当前还没有排行榜数据</view>
    </view>

    <view class="panel-card">
      <view class="row-between section-header">
        <view class="section-title">热门动态</view>
        <view class="section-link" bindtap="goSocial">进入动态广场 →</view>
      </view>
      <block wx:if="{{homeData.hotPosts.length}}">
        <block wx:for="{{homeData.hotPosts}}" wx:key="id">
          <view class="activity-card clickable-card" data-id="{{item.id}}" bindtap="openPostDetail" hover-class="card-hover">
            <view class="mini-eyebrow">动态</view>
            <view class="card-title">{{item.user.displayName || '校园跑友'}}</view>
            <view class="muted ellipsis-two">{{item.content || '这条动态暂时没有内容摘要'}}</view>
            <view class="pill-row card-pills">
              <view class="pill">点赞 {{item.likeCount || 0}}</view>
              <view class="pill">评论 {{item.commentCount || 0}}</view>
            </view>
          </view>
        </block>
      </block>
      <view wx:else class="empty-state">还没有热门动态，去动态页发布第一条吧</view>
    </view>

    <view class="panel-card">
      <view class="row-between section-header">
        <view class="section-title">轮播推荐</view>
        <view class="muted section-tip">支持点击跳转</view>
      </view>
      <block wx:if="{{homeData.banners.length}}">
        <swiper indicator-dots autoplay interval="3200" circular class="banner-swiper">
          <block wx:for="{{homeData.banners}}" wx:key="id">
            <swiper-item>
              <view
                class="banner-slide clickable-card"
                data-link-type="{{item.linkType}}"
                data-link-target="{{item.linkTarget}}"
                bindtap="openBanner"
                style="background-image: linear-gradient(160deg, rgba(34, 23, 18, 0.10), rgba(212, 75, 43, 0.20)), url({{item.imageUrl}});"
              >
                <view class="banner-chip">{{item.linkType || '推荐'}}</view>
                <view class="banner-content">
                  <view class="banner-title">{{item.title || '校园乐跑推荐'}}</view>
                  <view class="banner-subtitle">{{item.subtitle || '精彩内容会展示在这里'}}</view>
                </view>
              </view>
            </swiper-item>
          </block>
        </swiper>
      </block>
      <view wx:else class="empty-state">当前没有可展示的轮播内容</view>
    </view>
  </block>
</view>
