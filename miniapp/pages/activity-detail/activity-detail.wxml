<view class="page-wrap">
  <view wx:if="{{loading}}" class="panel-card">
    <view class="section-title">加载中</view>
    <view class="muted">正在获取活动详情。</view>
  </view>

  <view wx:if="{{!loading && errorMessage}}" class="panel-card">
    <view class="section-title">加载失败</view>
    <view class="muted">{{errorMessage}}</view>
    <button class="ghost-button" style="margin-top: 18rpx;" bindtap="loadData">重新加载</button>
  </view>

  <block wx:if="{{!loading && !errorMessage && activity}}">
    <view class="hero-card detail-hero">
      <view class="eyebrow">Activity</view>
      <view class="hero-title">{{activity.title || '未命名活动'}}</view>
      <view class="hero-subtitle">{{activity.location || '地点待定'}}</view>
      <view class="pill-row" style="margin-top: 18rpx;">
        <view class="pill">{{activity.status || '待发布'}}</view>
        <view class="pill">截止 {{activity.displayDeadline}}</view>
      </view>
    </view>

    <view class="panel-card">
      <view class="section-title">活动安排</view>
      <view class="info-row">
        <view class="muted">开始时间</view>
        <view>{{activity.displayStartTime}}</view>
      </view>
      <view class="info-row">
        <view class="muted">结束时间</view>
        <view>{{activity.displayEndTime}}</view>
      </view>
      <view class="info-row">
        <view class="muted">报名截止</view>
        <view>{{activity.displayDeadline}}</view>
      </view>
    </view>

    <view class="panel-card">
      <view class="section-title">活动介绍</view>
      <view class="content-copy">{{activity.description || '这场活动的详细介绍会显示在这里。'}}</view>
      <button class="accent-button" style="margin-top: 24rpx;" bindtap="register">报名活动</button>
    </view>
  </block>
</view>
