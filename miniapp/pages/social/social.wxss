.tab-strip {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tab-pill {
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.92);
  color: #6f5c52;
  font-size: 24rpx;
}

.tab-active {
  background: linear-gradient(135deg, #d44b2b, #c96b2a);
  color: #fff;
}

textarea {
  width: 100%;
}

.content-block {
  line-height: 1.8;
}

.comment-row {
  margin-bottom: 14rpx;
}

.comment-author {
  font-weight: 700;
}

.club-card,
.message-card {
  padding: 18rpx 0;
  border-bottom: 2rpx solid rgba(31, 26, 24, 0.06);
}

.club-card:last-child,
.message-card:last-child {
  border-bottom: none;
}

.task-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.member-row {
  padding: 10rpx 0;
}
