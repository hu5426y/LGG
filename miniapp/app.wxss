page {
  background: linear-gradient(180deg, #f7efe5 0%, #f5f1eb 100%);
  color: #1f1a18;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-wrap {
  padding: 24rpx;
}

.hero-card,
.panel-card,
.metric-card,
.post-card,
.activity-card {
  background: rgba(255, 251, 246, 0.94);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(109, 71, 40, 0.12);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.eyebrow {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(212, 75, 43, 0.12);
  color: #d44b2b;
  font-size: 22rpx;
  margin-bottom: 14rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.hero-subtitle,
.muted {
  color: #75665b;
  font-size: 26rpx;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.metric-label {
  font-size: 22rpx;
  color: #78685f;
}

.metric-value {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #1f1a18;
}

.accent-button {
  background: linear-gradient(135deg, #d44b2b, #c96b2a);
  color: #ffffff;
  border-radius: 999rpx;
}

.ghost-button {
  background: #fffaf4;
  color: #3b2c24;
  border: 2rpx solid rgba(59, 44, 36, 0.12);
  border-radius: 999rpx;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(31, 26, 24, 0.06);
  font-size: 22rpx;
}

.form-box {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.textarea-box,
.input-box {
  width: 100%;
  background: #fffdf8;
  border-radius: 22rpx;
  padding: 20rpx 24rpx;
  min-height: 88rpx;
  border: 2rpx solid rgba(33, 28, 26, 0.08);
}

.post-header,
.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.divider {
  height: 2rpx;
  background: rgba(31, 26, 24, 0.08);
  margin: 18rpx 0;
}

.empty-state {
  padding: 28rpx 8rpx 10rpx;
  color: #75665b;
  font-size: 26rpx;
}

.ellipsis-two {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
