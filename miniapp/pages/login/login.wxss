.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.login-hero {
  background: linear-gradient(145deg, #d44b2b, #77311f);
  color: #fff;
}

.login-eyebrow {
  background: rgba(255, 255, 255, 0.14);
  color: #fff;
}

.login-subtitle {
  color: rgba(255, 255, 255, 0.82);
}

.reserve-copy {
  margin-bottom: 18rpx;
}

.mini-pill {
  font-size: 24rpx;
}

.env-card {
  margin-top: 8rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(212, 75, 43, 0.06);
}

.env-label {
  font-size: 22rpx;
  color: #8b6c5d;
}

.env-value {
  margin: 10rpx 0 14rpx;
  font-size: 24rpx;
  color: #3b2c24;
  word-break: break-all;
}

.warning-banner {
  margin-top: 8rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(224, 146, 37, 0.14);
  color: #8b5200;
  font-size: 24rpx;
}

.error-banner {
  margin-top: 8rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(196, 58, 36, 0.1);
  color: #a63a24;
  font-size: 24rpx;
}
