<view class="page-wrap">
  <view class="hero-card">
    <view class="eyebrow">Profile</view>
    <view class="hero-title">{{profile.displayName || '校园跑者'}}</view>
    <view class="hero-subtitle">{{profile.college || '学院待完善'}} · {{profile.className || '班级待完善'}}</view>
    <view class="pill-row" style="margin-top: 18rpx;">
      <view class="pill">积分 {{profile.points}}</view>
      <view class="pill">Lv.{{profile.levelValue}}</view>
      <view class="pill">累计 {{profile.totalDistanceKm}} km</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="panel-card">
    <view class="section-title">加载中</view>
    <view class="muted">正在同步个人中心数据。</view>
  </view>

  <view wx:if="{{!loading && errorMessage}}" class="panel-card">
    <view class="section-title">加载失败</view>
    <view class="muted">{{errorMessage}}</view>
    <button class="ghost-button" style="margin-top: 18rpx;" bindtap="loadData">重新加载</button>
  </view>

  <block wx:if="{{!loading && !errorMessage}}">
    <view class="panel-card">
      <view class="section-title">最近跑步记录</view>
      <block wx:if="{{recentRuns.length}}">
        <block wx:for="{{recentRuns}}" wx:key="id">
          <view class="run-row" data-run-id="{{item.id}}" bindtap="viewRunDetail">
            <view class="row-between">
              <view class="run-distance">{{item.distanceKm || 0}} km</view>
              <view class="muted">{{item.displayFinishedAt}}</view>
            </view>
            <view class="row-between" style="margin-top: 12rpx;">
              <view class="muted">时长 {{item.displayDuration}}</view>
              <view class="muted">配速 {{item.displayPace}}</view>
            </view>
          </view>
        </block>
      </block>
      <view wx:else class="empty-state">你还没有有效跑步记录</view>
    </view>

    <view class="panel-card">
      <view class="section-title">已获得勋章</view>
      <block wx:if="{{badges.length}}">
        <view class="pill-row">
          <block wx:for="{{badges}}" wx:key="id">
            <view class="pill">{{item.name || '未命名勋章'}}</view>
          </block>
        </view>
      </block>
      <view wx:else class="empty-state">继续完成任务后，勋章会展示在这里</view>
    </view>

    <view class="panel-card">
      <view class="section-title">任务概览</view>
      <block wx:if="{{tasks.length}}">
        <block wx:for="{{tasks}}" wx:key="id">
          <view class="row-between list-row">
            <view>{{item.task.title || '未命名任务'}}</view>
            <view class="pill">{{item.currentValue || 0}} / {{item.task.goalValue || 0}}</view>
          </view>
        </block>
      </block>
      <view wx:else class="empty-state">当前没有任务数据</view>
    </view>
  </block>

  <button class="ghost-button logout-button" bindtap="logout">退出登录</button>
</view>
