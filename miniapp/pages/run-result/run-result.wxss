.result-map {
  width: 100%;
  height: 500rpx;
  border-radius: 24rpx;
}

.map-placeholder {
  height: 300rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(212, 75, 43, 0.08), rgba(212, 75, 43, 0.02));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.map-note {
  margin-top: 18rpx;
}
