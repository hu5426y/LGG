<view class="page-wrap">
  <view class="hero-card hero-spotlight">
    <view class="eyebrow">Campus Run</view>
    <view class="hero-title">欢迎回来，{{profile.displayName || '同学'}}</view>
    <view class="hero-subtitle">今天也把碎片时间跑成成绩，去完成你的下一段校园里程。</view>
    <view class="pill-row hero-pills">
      <view class="pill">累计 {{profile.totalDistanceKm}} km</view>
      <view class="pill">积分 {{profile.points}}</view>
      <view class="pill">Lv.{{profile.levelValue}}</view>
    </view>
    <button class="accent-button hero-action" bindtap="goRun">立即开始跑步</button>
  </view>

  <view wx:if="{{loading}}" class="panel-card">
    <view class="section-title">加载中</view>
    <view class="muted">正在同步首页数据，请稍候。</view>
  </view>

  <view wx:if="{{!loading && errorMessage}}" class="panel-card">
    <view class="section-title">加载失败</view>
    <view class="muted">{{errorMessage}}</view>
    <button class="ghost-button" style="margin-top: 18rpx;" bindtap="loadData">重新加载</button>
  </view>

  <block wx:if="{{!loading && !errorMessage}}">
    <view class="panel-card">
      <view class="row-between section-header">
        <view class="section-title">轮播推荐</view>
        <view class="muted section-tip">支持点击跳转</view>
      </view>
      <block wx:if="{{homeData.banners.length}}">
        <swiper indicator-dots autoplay interval="3200" circular class="banner-swiper">
          <block wx:for="{{homeData.banners}}" wx:key="id">
            <swiper-item>
              <view
                class="banner-slide clickable-card"
                data-link-type="{{item.linkType}}"
                data-link-target="{{item.linkTarget}}"
                bindtap="openBanner"
                style="background-image: linear-gradient(160deg, rgba(34, 23, 18, 0.10), rgba(212, 75, 43, 0.20)), url({{item.imageUrl}});"
              >
                <view class="banner-chip">{{item.linkType || '推荐'}}</view>
                <view class="banner-arrow">→</view>
                <view class="banner-content">
                  <view class="banner-title">{{item.title || '校园乐跑推荐'}}</view>
                  <view class="banner-subtitle">{{item.subtitle || '精彩内容会展示在这里'}}</view>
                </view>
              </view>
            </swiper-item>
          </block>
        </swiper>
      </block>
      <view wx:else class="empty-state">当前没有可展示的轮播内容</view>
    </view>

    <view class="metrics-grid">
      <view class="metric-card clickable-card metric-highlight" bindtap="goGrowthCenter" hover-class="card-hover">
        <view class="metric-icon">🏅</view>
        <view class="metric-label">进行中任务</view>
        <view class="metric-value">{{overview.tasks.length}}</view>
        <view class="metric-foot">查看成长中心 →</view>
      </view>
      <view class="metric-card clickable-card metric-highlight" bindtap="goGrowthCenter" hover-class="card-hover">
        <view class="metric-icon">✨</view>
        <view class="metric-label">已获勋章</view>
        <view class="metric-value">{{overview.badges.length}}</view>
        <view class="metric-foot">查看成长中心 →</view>
      </view>
    </view>

    <view class="panel-card clickable-card" bindtap="goGrowthCenter" hover-class="card-hover">
      <view class="row-between section-header">
        <view class="section-title">任务进度</view>
        <view class="section-link">进入成长中心 →</view>
      </view>
      <block wx:if="{{overview.tasks.length}}">
        <block wx:for="{{overview.tasks}}" wx:key="id">
          <view class="row-between list-row task-row">
            <view>
              <view>{{item.task.title || '未命名任务'}}</view>
              <view class="muted">{{item.currentValue || 0}} / {{item.task.goalValue || 0}}</view>
            </view>
            <view class="pill">{{item.completed ? '已完成' : (item.task.taskType || '进行中')}}</view>
          </view>
        </block>
      </block>
      <view wx:else class="empty-state">暂时没有任务进度数据</view>
    </view>

    <view class="panel-card clickable-card" bindtap="goRanking" hover-class="card-hover">
      <view class="row-between section-header">
        <view class="section-title">排行榜 Top 3</view>
        <view class="section-link">查看完整榜单 →</view>
      </view>
      <block wx:if="{{homeData.leaderboard.length}}">
        <block wx:for="{{homeData.leaderboard}}" wx:key="userId">
          <view class="row-between list-row rank-row">
            <view class="rank-name">
              <text class="rank-badge">#{{index + 1}}</text>
              <text>{{item.displayName || '匿名同学'}}</text>
            </view>
            <view class="pill">{{item.distanceKm || 0}} km</view>
          </view>
        </block>
      </block>
      <view wx:else class="empty-state">当前还没有排行榜数据</view>
    </view>

    <view class="panel-card">
      <view class="row-between section-header">
        <view class="section-title">热门动态</view>
        <view class="section-link" bindtap="goSocial">进入动态广场 →</view>
      </view>
      <block wx:if="{{homeData.hotPosts.length}}">
        <block wx:for="{{homeData.hotPosts}}" wx:key="id">
          <view class="activity-card clickable-card" data-id="{{item.id}}" bindtap="openPostDetail" hover-class="card-hover">
            <view class="row-between">
              <view class="mini-eyebrow">动态</view>
              <view class="section-link">查看详情 →</view>
            </view>
            <view class="card-title">{{item.user.displayName || '校园跑友'}}</view>
            <view class="muted ellipsis-two">{{item.content || '这条动态暂时没有内容摘要'}}</view>
            <view class="pill-row card-pills">
              <view class="pill">点赞 {{item.likeCount || 0}}</view>
              <view class="pill">评论 {{item.commentCount || 0}}</view>
            </view>
          </view>
        </block>
      </block>
      <view wx:else class="empty-state">还没有热门动态，去动态页发布第一条吧</view>
    </view>

    <view class="panel-card">
      <view class="row-between section-header">
        <view class="section-title">推荐活动</view>
        <view class="section-link" bindtap="goActivities">查看更多 →</view>
      </view>
      <block wx:if="{{homeData.recommendedActivities.length}}">
        <block wx:for="{{homeData.recommendedActivities}}" wx:key="id">
          <view class="activity-card clickable-card" data-id="{{item.id}}" bindtap="openActivityDetail" hover-class="card-hover">
            <view class="row-between">
              <view>
                <view class="card-title">{{item.title || '未命名活动'}}</view>
                <view class="muted">{{item.location || '地点待定'}}</view>
              </view>
              <view class="pill">{{item.status || '待发布'}}</view>
            </view>
            <view class="section-link activity-link">查看活动详情 →</view>
          </view>
        </block>
        <button class="ghost-button" bindtap="goActivities">查看更多活动</button>
      </block>
      <view wx:else class="empty-state">当前没有推荐活动</view>
    </view>

    <view class="panel-card">
      <view class="row-between section-header">
        <view class="section-title">训练教程</view>
        <view class="section-link" bindtap="goActivities">浏览全部 →</view>
      </view>
      <block wx:if="{{homeData.tutorials.length}}">
        <block wx:for="{{homeData.tutorials}}" wx:key="id">
          <view class="activity-card clickable-card" data-id="{{item.id}}" bindtap="openTutorialDetail" hover-class="card-hover">
            <view class="mini-eyebrow">训练</view>
            <view class="card-title">{{item.title || '训练教程'}}</view>
            <view class="muted">{{item.summary || '教程摘要将在这里显示'}}</view>
            <view class="section-link tutorial-link">阅读详情 →</view>
          </view>
        </block>
      </block>
      <view wx:else class="empty-state">当前没有可展示的跑步教程</view>
    </view>
  </block>
</view>
